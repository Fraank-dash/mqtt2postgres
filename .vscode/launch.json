{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "Pytest: Current File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-q"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "Pytest: Named Test Expression",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests",
        "-k",
        "${input:pytestExpression}",
        "-q"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "mqtt2postgres: main.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "DATACONTRACT_POSTGRES_USERNAME": "postgres",
        "DATACONTRACT_POSTGRES_PASSWORD": "postgres"
      },
      "args": [
        "--log-format",
        "text",
        "--log-level",
        "DEBUG",
        "--config-snapshot-path",
        "${workspaceFolder}/.tmp/config-snapshot.json",
        "--broker-contract",
        "${workspaceFolder}/contracts/raw/mqtt_broker.odcs.yaml",
        "--derived-contract",
        "${workspaceFolder}/contracts/derived/tbl_broker_metrics.odcs.yaml",
        "--derived-contract",
        "${workspaceFolder}/contracts/derived/tbl_sensor_temp.odcs.yaml"
      ]
    }
  ],
  "inputs": [
    {
      "id": "pytestExpression",
      "type": "promptString",
      "description": "Pytest -k expression (test name, class name, or pattern)",
      "default": "test_"
    }
  ]
}
